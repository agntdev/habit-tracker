[
  {
    "name": "/skip shows empty state",
    "steps": [
      {
        "send": { "text": "/skip" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "No active habits to skip." } }
        ]
      }
    ]
  },
  {
    "name": "/skip shows habit list after creation",
    "steps": [
      {
        "send": { "text": "/add" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What habit would you like to build?" } }
        ]
      },
      {
        "send": { "text": "Journal" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "add:freq:daily" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "22:00" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "add:confirm:yes" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/skip" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Tap a habit to skip today:" } }
        ]
      }
    ]
  }
]
